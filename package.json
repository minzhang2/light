{
  "name": "nextjs-app",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.23.0",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate --schema prisma/schema.prisma && prisma generate --schema prisma/schema.local.prisma && prisma db push --schema prisma/schema.prisma && next build",
    "start": "next start",
    "lint": "node ./node_modules/eslint/bin/eslint.js",
    "db:generate": "prisma generate --schema prisma/schema.prisma && prisma generate --schema prisma/schema.local.prisma",
    "db:push": "prisma db push --schema prisma/schema.local.prisma",
    "db:push:prod": "prisma db push --schema prisma/schema.prisma",
    "user:grant-admin": "node scripts/grant-admin.mjs"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@base-ui/react": "^1.3.0",
    "@prisma/adapter-better-sqlite3": "^7.5.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.577.0",
    "lunar-javascript": "^1.7.7",
    "next": "16.2.0",
    "next-auth": "^4.24.13",
    "nodemailer": "^7.0.13",
    "pg": "^8.16.3",
    "react": "19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.4",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^25",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
    "prisma": "^7.5.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
