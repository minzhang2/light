# Prisma
# Local development (default: SQLite)
LOCAL_DATABASE_URL="file:./dev.db"
# Optional fallback used when LOCAL_DATABASE_URL is missing:
DATABASE_URL="file:./dev.db"

# Vercel + Neon integration will auto-inject these for deployment:
POSTGRES_PRISMA_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
POSTGRES_URL_NON_POOLING="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
ADMIN_EMAILS="admin1@example.com,admin2@example.com"

# Social OAuth (optional)
# Google OAuth:
# - Authorized JavaScript origins: http://localhost:3000
# - Authorized redirect URI:      http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Apple OAuth:
# - Redirect URI:                 http://localhost:3000/api/auth/callback/apple
# - AUTH_APPLE_SECRET is the generated client secret JWT (or equivalent secret string)
AUTH_APPLE_ID=""
AUTH_APPLE_SECRET=""

# SMTP (required for real email code delivery)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="no-reply@example.com"
