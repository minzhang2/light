generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          String    @default("user")
  accounts      Account[]
  sessions      Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String @unique
  expires    DateTime

  @@unique([identifier, token])
}

model EmailOtp {
  id        String   @id @default(cuid())
  email     String
  purpose   String   @default("login")
  codeHash  String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email, purpose, createdAt])
}

model InviteCode {
  id             String   @id @default(cuid())
  code           String   @unique
  normalizedCode String   @unique
  note           String?
  createdByEmail String?
  usedByEmail    String?
  usedAt         DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([createdAt])
  @@index([usedAt])
}

model ManagedKey {
  id              String    @id @default(cuid())
  name            String
  aliases         String?
  groupName       String
  protocol        String
  secret          String
  baseUrl         String
  model           String?
  launchCommand   String?
  extraEnv        String?
  availableModels String?
  fingerprint     String    @unique
  isTestable      Boolean   @default(true)
  isPinned        Boolean   @default(false)
  lastTestStatus  String?
  lastTestMessage String?
  lastTestAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([groupName, updatedAt])
  @@index([name])
}
